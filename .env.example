# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Claude scoring runs through the Claude Agent SDK, which delegates to your
# locally-installed Claude Code (uses your Claude Max subscription). No API key
# needed. Make sure `claude` is installed and you have run `claude login` once.
# Install: https://docs.claude.com/claude-code

# Apify (optional — enables Google Maps data collection for research)
APIFY_API_TOKEN=

# App password — gates the Streamlit app from public access. Ask Josue.
APP_PASSWORD=
